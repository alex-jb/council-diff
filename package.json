{
  "name": "council-diff",
  "version": "0.3.1",
  "description": "5-voice AI council for any decision, with optional Claude Fable 5 Oracle adjudication. Paste a question, get 5 specialist perspectives in parallel, see where they agree and disagree. Brier-audited at resolution.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "node --test --import tsx examples/test.ts",
    "example": "tsx examples/founder.ts",
    "example:oracle": "tsx examples/oracle.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alex-jb/council-diff.git"
  },
  "keywords": [
    "ai",
    "claude",
    "claude-fable-5",
    "fable-5",
    "anthropic",
    "agents",
    "decision",
    "council",
    "multi-agent",
    "oracle",
    "brier"
  ],
  "author": "Alex Xiaoyu Ji",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alex-jb/council-diff/issues"
  },
  "homepage": "https://github.com/alex-jb/council-diff#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
